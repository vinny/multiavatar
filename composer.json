{
	"name": "vinny/multiavatar",
	"type": "phpbb-extension",
	"description": "Adds Multiavatar as a phpBB avatar provider.",
	"homepage": "https://github.com/vinny/multiavatar",
	"version": "1.0.0",
	"time": "2026-04-28",
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "Vinny",
			"role": "Developer"
		}
	],
	"require": {
		"php": ">=7.4.0",
		"composer/installers": "^1.0 || ^2.0",
		"multiavatar/multiavatar-php": "^1.0"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	},
	"extra": {
		"display-name": "Multiavatar",
		"soft-require": {
			"phpbb/phpbb": ">=3.3.0,<3.4.0"
		},
		"version-check": {
			"host": "www.phpbb.com",
			"directory": "/customise/db/extension/multiavatar",
			"filename": "version_check",
			"ssl": true
		}
	}
}
